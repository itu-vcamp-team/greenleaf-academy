APP_ENV=development

# JWT imzalamak için uzun, rastgele bir string kullanın.
# Üretim: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_long_random_hex_string_in_production

# Use 'postgres' as host if running inside Docker Compose, 'localhost' if running locally
# Port is 5432 inside Docker network, 5435 if accessed from host
DATABASE_URL=postgresql+asyncpg://greenleaf:greenleaf_dev@postgres:5432/greenleaf_db

REDIS_URL=redis://redis:6379/0

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SES_REGION=eu-north-1
MAIL_FROM_ADDRESS=noreply@greenleafakademi.com
MAIL_FROM_NAME=Greenleaf Akademi

GREENLEAF_GLOBAL_API_URL=https://greenleaf-global.com/office/login

# Render Disk veya lokal yazma dizini
# Production (Render): /var/data/uploads  ← Render disk mount path'i
# Lokal dev:           ./uploads          ← proje klasöründe oluşturulur
UPLOAD_DIR=./uploads

# CORS: production'da gerçek frontend URL'ini girin
FRONTEND_URL=http://localhost:3000

# Production'da Render'daki tüm subdomain'leri kapsamak için regex (opsiyonel)
# CORS_ALLOWED_ORIGIN_REGEX=https?://([a-z0-9-]+\.)*greenleafakademi\.com
